<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>YouTube Analytics Report — Figuring Out Channel by Prabhas(Ds)</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;500;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0a0f;
  --bg2: #111118;
  --bg3: #18181f;
  --bg4: #1e1e27;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.12);
  --text: #f0f0f5;
  --text2: #9090a8;
  --text3: #5a5a72;
  --accent: #e63946;
  --accent2: #ff6b6b;
  --blue: #4a90d9;
  --green: #2ecc71;
  --amber: #f39c12;
  --purple: #9b59b6;
  --teal: #1abc9c;
  --mono: 'DM Mono', monospace;
  --display: 'Syne', sans-serif;
  --body: 'DM Sans', sans-serif;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--body);
  font-size: 14px;
  line-height: 1.6;
  min-height: 100vh;
}

/* GRID NOISE BACKGROUND */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
  z-index: 0;
}

.container { max-width: 1280px; margin: 0 auto; padding: 0 2rem; position: relative; z-index: 1; }

/* ── HEADER ── */
.header {
  padding: 3rem 0 2rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 2.5rem;
}
.header-inner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 1.5rem;
}
.header-left {}
.header-eyebrow {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--accent);
  letter-spacing: .15em;
  text-transform: uppercase;
  margin-bottom: .5rem;
}
.header-title {
  font-family: var(--display);
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 800;
  line-height: 1.1;
  color: var(--text);
  letter-spacing: -.02em;
}
.header-title span { color: var(--accent); }
.header-sub {
  font-size: 13px;
  color: var(--text2);
  margin-top: .75rem;
  display: flex;
  flex-wrap: wrap;
  gap: .5rem;
  align-items: center;
}
.header-sub .dot { color: var(--text3); }
.header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: .5rem;
}
.badge {
  display: inline-block;
  font-family: var(--mono);
  font-size: 10px;
  padding: 3px 10px;
  border-radius: 2px;
  letter-spacing: .05em;
  text-transform: uppercase;
}
.badge-red { background: rgba(230,57,70,.15); color: var(--accent2); border: 1px solid rgba(230,57,70,.25); }
.badge-green { background: rgba(46,204,113,.1); color: #2ecc71; border: 1px solid rgba(46,204,113,.2); }
.badge-amber { background: rgba(243,156,18,.1); color: var(--amber); border: 1px solid rgba(243,156,18,.2); }
.badge-blue { background: rgba(74,144,217,.1); color: var(--blue); border: 1px solid rgba(74,144,217,.2); }
.source-note { font-family: var(--mono); font-size: 10px; color: var(--text3); text-align: right; line-height: 1.7; }

/* ── SECTION ── */
.section { margin-bottom: 3rem; }
.section-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.5rem;
}
.section-num {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--accent);
  background: rgba(230,57,70,.1);
  border: 1px solid rgba(230,57,70,.2);
  padding: 2px 8px;
  border-radius: 2px;
}
.section-title {
  font-family: var(--display);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--text2);
}
.section-line { flex: 1; height: 1px; background: var(--border); }

/* ── KPI GRID ── */
.kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; margin-bottom: 1.5rem; }
.kpi {
  background: var(--bg2);
  padding: 1.25rem 1.25rem 1rem;
  position: relative;
  overflow: hidden;
  transition: background .2s;
}
.kpi:hover { background: var(--bg3); }
.kpi::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--accent);
  opacity: 0;
  transition: opacity .2s;
}
.kpi:hover::before { opacity: 1; }
.kpi-label { font-family: var(--mono); font-size: 10px; color: var(--text3); letter-spacing: .08em; text-transform: uppercase; margin-bottom: .5rem; }
.kpi-value { font-family: var(--display); font-size: 28px; font-weight: 800; color: var(--text); line-height: 1; }
.kpi-delta { font-size: 11px; margin-top: .4rem; }
.up { color: var(--green); }
.dn { color: var(--accent2); }
.neu { color: var(--text3); }

/* ── CHART CARDS ── */
.grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.grid3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
.card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1.25rem;
  position: relative;
  overflow: hidden;
}
.card.span2 { grid-column: span 2; }
.card.span3 { grid-column: span 3; }
.card-label {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text3);
  letter-spacing: .08em;
  text-transform: uppercase;
  margin-bottom: .9rem;
}
.chart-wrap { position: relative; width: 100%; }

/* ── LEGEND ── */
.legend { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: .75rem; }
.legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--text2); }
.legend-dot { width: 8px; height: 8px; border-radius: 1px; flex-shrink: 0; }

/* ── TABS ── */
.tabs { display: flex; gap: 4px; margin-bottom: 1rem; flex-wrap: wrap; }
.tab {
  font-family: var(--mono);
  font-size: 10px;
  padding: 4px 12px;
  border: 1px solid var(--border2);
  border-radius: 2px;
  cursor: pointer;
  background: transparent;
  color: var(--text2);
  letter-spacing: .05em;
  text-transform: uppercase;
  transition: all .15s;
}
.tab:hover { background: var(--bg4); color: var(--text); }
.tab.on { background: var(--accent); color: #fff; border-color: var(--accent); }

/* ── PROGRESS BARS ── */
.prog-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.prog-label { font-size: 12px; color: var(--text2); width: 140px; flex-shrink: 0; }
.prog-wrap { flex: 1; height: 6px; background: var(--bg4); border-radius: 3px; overflow: hidden; }
.prog-fill { height: 100%; border-radius: 3px; transition: width .8s cubic-bezier(.4,0,.2,1); }
.prog-val { font-family: var(--mono); font-size: 11px; min-width: 36px; text-align: right; }

/* ── INSIGHT BOXES ── */
.insight-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.insight-col-title {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text3);
  letter-spacing: .1em;
  text-transform: uppercase;
  margin-bottom: .6rem;
  padding-bottom: .4rem;
  border-bottom: 1px solid var(--border);
}
.ins {
  padding: .6rem .9rem;
  border-left: 2px solid var(--blue);
  background: rgba(74,144,217,.05);
  border-radius: 0 4px 4px 0;
  margin-bottom: .5rem;
  font-size: 12px;
  line-height: 1.6;
  color: var(--text2);
}
.ins.warn { border-color: var(--amber); background: rgba(243,156,18,.05); }
.ins.danger { border-color: var(--accent); background: rgba(230,57,70,.05); }
.ins.good { border-color: var(--green); background: rgba(46,204,113,.05); }

/* ── MISSING BOX ── */
.missing {
  background: rgba(230,57,70,.06);
  border: 1px solid rgba(230,57,70,.2);
  border-radius: 6px;
  padding: .9rem 1rem;
  margin-top: .9rem;
}
.missing-title {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--accent2);
  letter-spacing: .1em;
  text-transform: uppercase;
  margin-bottom: .5rem;
}
.missing-body { font-size: 12px; color: rgba(255,107,107,.8); line-height: 1.8; }

/* ── RETENTION LABELS ── */
.ret-labels { display: flex; justify-content: space-between; font-family: var(--mono); font-size: 10px; color: var(--text3); margin-top: .4rem; }
.ret-pills { display: flex; gap: .5rem; margin-top: .8rem; flex-wrap: wrap; }
.ret-pill { font-size: 11px; padding: 3px 10px; border-radius: 3px; }

/* ── BENCHMARK NOTE ── */
.bench-note {
  font-size: 11px;
  color: var(--text3);
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: .6rem .9rem;
  margin-top: .8rem;
  line-height: 1.7;
}

/* ── GROWTH PROJECTIONS ── */
.proj-pills { display: flex; gap: .6rem; margin-top: .8rem; flex-wrap: wrap; }
.proj-pill { font-size: 11px; padding: 4px 12px; border-radius: 3px; }

/* ── FOOTER ── */
.footer {
  border-top: 1px solid var(--border);
  padding: 2rem 0;
  margin-top: 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
}
.footer-left { font-family: var(--mono); font-size: 10px; color: var(--text3); line-height: 1.8; }
.footer-right { font-family: var(--mono); font-size: 10px; color: var(--text3); text-align: right; line-height: 1.8; }

/* ── ANIMATIONS ── */
@keyframes fadeUp { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
.section { animation: fadeUp .5s ease both; }
.section:nth-child(1) { animation-delay: .05s; }
.section:nth-child(2) { animation-delay: .1s; }
.section:nth-child(3) { animation-delay: .15s; }
.section:nth-child(4) { animation-delay: .2s; }
.section:nth-child(5) { animation-delay: .25s; }
.section:nth-child(6) { animation-delay: .3s; }

/* ── RESPONSIVE ── */
@media(max-width: 768px) {
  .grid2, .grid3, .insight-grid { grid-template-columns: 1fr; }
  .card.span2, .card.span3 { grid-column: 1; }
  .kpi-value { font-size: 22px; }
  .header-title { font-size: 26px; }
  .prog-label { width: 110px; }
}

/* ── ML SECTION ── */
.ml-intro {
  display: flex; align-items: flex-start; gap: 1rem;
  background: var(--bg3); border: 1px solid var(--border2);
  border-radius: 8px; padding: 1.1rem 1.25rem; margin-bottom: 1.5rem;
}
.ml-intro-icon { font-size: 24px; color: var(--accent); line-height: 1; margin-top: 2px; flex-shrink: 0; }
.ml-intro-title { font-family: var(--display); font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: .3rem; }
.ml-intro-sub { font-size: 12px; color: var(--text2); line-height: 1.7; }
.ml-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
.ml-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 8px; padding: 1.1rem; display: flex; flex-direction: column; gap: .75rem;
  transition: border-color .2s;
}
.ml-card:hover { border-color: var(--border2); }
.ml-card-header {}
.ml-tag {
  font-family: var(--mono); font-size: 9px; color: var(--accent);
  background: rgba(230,57,70,.1); border: 1px solid rgba(230,57,70,.2);
  padding: 2px 8px; border-radius: 2px; display: inline-block;
  letter-spacing: .08em; text-transform: uppercase; margin-bottom: .4rem;
}
.ml-card-title { font-family: var(--display); font-size: 14px; font-weight: 700; color: var(--text); line-height: 1.3; }
.ml-card-body { display: flex; flex-direction: column; gap: .6rem; }
.ml-label {
  font-family: var(--mono); font-size: 9px; padding: 1px 6px;
  border-radius: 2px; margin-right: 5px; text-transform: uppercase; letter-spacing: .07em;
}
.ml-label.problem { background: rgba(230,57,70,.12); color: var(--accent2); }
.ml-label.solution { background: rgba(74,144,217,.12); color: var(--blue); }
.ml-problem, .ml-solution { font-size: 11px; color: var(--text2); line-height: 1.6; }
.ml-impact {
  display: flex; align-items: baseline; gap: .4rem;
  padding: .5rem .75rem; background: var(--bg4);
  border-radius: 4px; border-left: 2px solid var(--green);
}
.ml-impact-num { font-family: var(--display); font-size: 20px; font-weight: 800; color: var(--green); }
.ml-impact-label { font-family: var(--mono); font-size: 10px; color: var(--text3); }
.ml-card-chart { background: var(--bg3); border-radius: 5px; padding: .75rem; }
.ml-chart-label { font-family: var(--mono); font-size: 9px; color: var(--text3); letter-spacing: .07em; text-transform: uppercase; margin-bottom: .5rem; }
.ml-summary {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 8px; padding: 1.25rem;
}
.ml-summary-title { font-family: var(--display); font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 1rem; }
.ml-stack { display: flex; flex-direction: column; gap: .75rem; }
.ml-stack-row { display: flex; align-items: flex-start; gap: 1rem; }
.ml-stack-phase { font-family: var(--mono); font-size: 10px; color: var(--text3); width: 110px; flex-shrink: 0; padding-top: 3px; letter-spacing: .05em; }
.ml-stack-items { display: flex; flex-wrap: wrap; gap: .4rem; }
.ml-stack-tag { font-size: 11px; padding: 4px 10px; border-radius: 3px; }
.ml-stack-tag.easy { background: rgba(46,204,113,.1); color: var(--green); border: 1px solid rgba(46,204,113,.2); }
.ml-stack-tag.medium { background: rgba(243,156,18,.1); color: var(--amber); border: 1px solid rgba(243,156,18,.2); }
.ml-stack-tag.hard { background: rgba(155,89,182,.1); color: var(--purple); border: 1px solid rgba(155,89,182,.2); }

/* ── EMAIL SECTION ── */
.email-context { background: var(--bg3); border: 1px solid var(--border); border-radius: 6px; padding: .9rem 1.1rem; margin-bottom: 1.25rem; }
.email-tabs { display: flex; gap: 6px; margin-bottom: 1rem; flex-wrap: wrap; }
.etab {
  font-family: var(--mono); font-size: 11px; padding: 6px 16px;
  border: 1px solid var(--border2); border-radius: 3px;
  cursor: pointer; background: transparent; color: var(--text2);
  letter-spacing: .05em; transition: all .15s;
}
.etab:hover { background: var(--bg4); color: var(--text); }
.etab.on { background: var(--accent); color: #fff; border-color: var(--accent); }
.email-wrapper {}
.email-card {
  background: var(--bg2); border: 1px solid var(--border2);
  border-radius: 8px; overflow: hidden;
}
.email-card.hidden { display: none; }
.email-meta-row { padding: 1rem 1.25rem .75rem; display: flex; flex-direction: column; gap: .3rem; background: var(--bg3); }
.email-meta { font-size: 12px; color: var(--text2); }
.email-meta-label { font-family: var(--mono); font-size: 10px; color: var(--text3); margin-right: .4rem; text-transform: uppercase; letter-spacing: .07em; }
.email-divider { height: 1px; background: var(--border); }
.email-body {
  padding: 1.5rem 1.75rem; font-family: var(--body); font-size: 14px;
  color: var(--text2); line-height: 1.9; display: flex; flex-direction: column; gap: .9rem;
}
.email-body p { margin: 0; }
.email-body em { color: var(--text); font-style: normal; font-weight: 500; }
.email-sig { color: var(--text); font-size: 13px; border-top: 1px solid var(--border); padding-top: .9rem; margin-top: .4rem; }
.email-notes { padding: 1rem 1.25rem; background: var(--bg3); border-top: 1px solid var(--border); }
.email-note-title { font-family: var(--mono); font-size: 9px; color: var(--text3); letter-spacing: .1em; text-transform: uppercase; margin-bottom: .6rem; }
.email-note-item { font-size: 12px; line-height: 1.6; margin-bottom: .4rem; padding-left: .9rem; position: relative; }
.email-note-item::before { content: '→'; position: absolute; left: 0; }
.email-note-item.good { color: rgba(46,204,113,.8); }
.email-note-item.warn { color: rgba(243,156,18,.8); }

/* Scrollbar */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--bg4); border-radius: 3px; }
</style>
</head>
<body>

<div class="container">

<!-- HEADER -->
<header class="header">
  <div class="header-inner">
    <div class="header-left">
      <div class="header-eyebrow">YouTube Analytics Report · Apr 2026</div>
      <h1 class="header-title">Figuring Out<br><span>Channel Intelligence</span></h1>
      <div class="header-sub">
        <span>Business &amp; Entrepreneurship</span>
        <span class="dot">·</span>
        <span>India's #1 Business Podcast</span>
        <span class="dot">·</span>
        <span>16.8M Subscribers</span>
      </div>
      <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.9rem;">
        <span class="badge badge-red">India #1 Business Podcast</span>
        <span class="badge badge-green">Global Top 100 Podcaster</span>
        <span class="badge badge-amber">Forbes 30 Under 30 · 2023</span>
        <span class="badge badge-blue">540+ Episodes</span>
      </div>
    </div>
    <div class="header-right">
      <div class="source-note">
        Sources: HypeAuditor · SocialBlade<br>
        SpeakRJ · SocialCounts · Whosthat360<br>
        Last updated: April 2026
      </div>
    </div>
  </div>
</header>

<!-- S1: CHANNEL OVERVIEW -->
<section class="section">
  <div class="section-header">
    <span class="section-num">01</span>
    <span class="section-title">Channel Overview</span>
    <div class="section-line"></div>
  </div>

  <div class="kpi-grid">
    <div class="kpi">
      <div class="kpi-label">Subscribers</div>
      <div class="kpi-value">16.8M</div>
      <div class="kpi-delta up">+4.67% monthly growth rate</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Total Views</div>
      <div class="kpi-value">1.7B+</div>
      <div class="kpi-delta up">All-time cumulative</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Total Videos</div>
      <div class="kpi-value">2,200+</div>
      <div class="kpi-delta neu">Since Jun 2009</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Avg Video Length</div>
      <div class="kpi-value">83 min</div>
      <div class="kpi-delta neu">Long-form dominant</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Engagement Rate</div>
      <div class="kpi-value">3.96%</div>
      <div class="kpi-delta up">Rated "Good" vs peers</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Avg Likes / Video</div>
      <div class="kpi-value">~14K</div>
      <div class="kpi-delta neu">Based on recent uploads</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Monthly YT Income</div>
      <div class="kpi-value">$9–12K</div>
      <div class="kpi-delta up">AdSense only (est.)</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Active Audience</div>
      <div class="kpi-value">~5.2%</div>
      <div class="kpi-delta dn">Below 8% benchmark</div>
    </div>
  </div>

  <div class="card">
    <div class="card-label">Monthly views trend — estimated (millions)</div>
    <div class="chart-wrap" style="height:200px">
      <canvas id="c_monthly" role="img" aria-label="Monthly views trend May 2025 to Apr 2026"></canvas>
    </div>
  </div>
</section>

<!-- S2: VIEWS VS SUBSCRIBERS GAP -->
<section class="section">
  <div class="section-header">
    <span class="section-num">02</span>
    <span class="section-title">Views vs Subscribers Gap</span>
    <div class="section-line"></div>
  </div>

  <div class="grid2">
    <div class="card">
      <div class="card-label">Subscribers vs avg views per video</div>
      <div class="legend">
        <div class="legend-item"><span class="legend-dot" style="background:#4a90d9"></span>Subscribers (M)</div>
        <div class="legend-item"><span class="legend-dot" style="background:#f39c12"></span>Avg Views / Video (×100K)</div>
      </div>
      <div class="chart-wrap" style="height:220px">
        <canvas id="c_gap" role="img" aria-label="Subscriber to average views gap comparison"></canvas>
      </div>
