// ML2: Day heatmap
const heatVals = [62, 58, 71, 94, 82, 55, 88];
const heatColors = heatVals.map(v => {
  const t = v / 100;
  const r = Math.round(14 + (230 - 14) * t);
  const g = Math.round(14 + (57 - 14) * (1 - t) + 139 * t);
  const b = Math.round(31 + (70 - 31) * (1 - t) + 217 * t * 0.3);
  return `rgba(${r},${g+30},${b+80},${0.3 + t * 0.7})`;
});
const heatContainer = document.getElementById('heatmap_days');
if (heatContainer) {
  heatVals.forEach((val, i) => {
    const cell = document.createElement('div');
    cell.style.cssText = `height:40px;border-radius:3px;background:${heatColors[i]};display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:10px;color:rgba(255,255,255,0.8);position:relative;`;
    cell.title = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'][i] + ': ' + val + '% engagement';
    cell.textContent = val + '%';
    heatContainer.appendChild(cell);
  });
}

